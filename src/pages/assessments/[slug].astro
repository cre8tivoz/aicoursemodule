---
import Base from "@/layouts/Base.astro";
import { marked } from "marked";

export async function getStaticPaths() {
  const modules = import.meta.glob("/src/content/assessments/**/*.md", { query: "raw" });
  return Object.entries(modules).map(([path, loader]) => {
    const slug = path.split("/").pop()?.replace(".md", "") ?? "";
    return {
      params: { slug },
      props: { loader },
    };
  });
}

const { loader } = Astro.props;
const rawModule = await loader();
const rawContent = typeof rawModule === "string" ? rawModule : (rawModule as any).default ?? String(rawModule);
const contentHtml = marked.parse(rawContent) as string;
---

<Base title="Assessment">
  <article class="assessment-sheet">
    <div set:html={contentHtml} />
  </article>
</Base>
