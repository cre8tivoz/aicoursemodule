---
import Base from "@/layouts/Base.astro";
import { getCollection } from "astro:content";

// Fetch all collections
const lessons = await getCollection("lessons");
const modules = await getCollection("modules");
const assessments = await getCollection("assessments");

// Sort modules by id
const sortedModules = modules.sort((a, b) => a.data.id.localeCompare(b.data.id));

// Total lesson count for progress
const totalLessons = lessons.length;
const totalAssessments = assessments.length;
const courseDescription = `AQF Level 5 course covering static-site generation, deployment workflows, and AI-assisted tooling. ${totalLessons} modules with ${totalAssessments} check-in assessments.`;
---

<Base title="AI Essentials for Qualifiers — Course Home">
  <div class="home-layout">
    <!-- Hero -->
    <section class="home-desk">
      <div class="home-desk__hero-row">
        <div class="home-desk__hero-text">
          <p class="type-label" style="color: var(--color-accent);">AQF Level 5</p>
          <h1 class="home-desk__title">AI Essentials for Qualifiers</h1>
          <p class="home-desk__lede">
            {courseDescription}
          </p>
          <p class="home-desk__lede" style="margin-top: var(--space-md);">
            This is a hands-on, progression-based course. Each module builds on the last.
            Use N/P to navigate between pages, or browse the syllabus below.
          </p>
          {totalAssessments > 0 && (
            <p style="margin-top: var(--space-md); color: var(--color-text-muted); font-size: var(--type-secondary);">
              You have {totalAssessments} assessments across {sortedModules.length} modules.
            </p>
          )}
        </div>
        <img src="/images/logo.png" alt="" class="home-desk__hero-logo" />
      </div>
    </section>

    <!-- Course Map / Syllabus -->
    <section id="course-map" aria-labelledby="syllabus-heading">
      <div class="syllabus__head">
        <h2 class="syllabus__heading" id="syllabus-heading">Course Map</h2>
        <p class="syllabus__intro">
          {sortedModules.length} modules &middot; {totalLessons} lessons &middot; {totalAssessments} assessments
        </p>
      </div>

      <!-- Module jump links -->
      <div class="syllabus-jump" aria-label="Jump to module">
        <span class="syllabus-jump__label" style="font-family: var(--font-ui); font-size: var(--type-caption); font-weight: 600;">Jump:</span>
        <ul class="syllabus-jump__list">
          {sortedModules.map((mod) => (
            <li>
              <a href={"#module-" + mod.data.id} class="syllabus-jump__link" aria-label={"Jump to " + mod.data.title}>
                M{mod.data.id}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Module list -->
      {sortedModules.map((mod) => {
        // Get lessons for this module
        const modLessons = lessons
          .filter((l) => l.data.module === mod.data.id)
          .sort((a, b) => a.data.lesson.localeCompare(b.data.lesson));

        // Get assessment for this module
        const modAssessment = assessments.find((a) => a.data.module === mod.data.id);
        const tint = mod.data.tint ?? "var(--color-accent)";

        return (
          <details class="syllabus-module" id={"module-" + mod.data.id} open={mod.data.id === "01"}>
            <summary class="syllabus-module__toggle">
              <div class="syllabus-module__inner">
                <span class="syllabus-module__tint" aria-hidden="true"></span>
                <div class="syllabus-module__text">
                  <p class="syllabus-module__eyebrow type-label">Module {mod.data.id}</p>
                  <h3 class="syllabus-module__title">{mod.data.title}</h3>
                  {mod.data.summary && <p class="syllabus-module__summary">{mod.data.summary}</p>}
                </div>
                {mod.data.image && <img src={mod.data.image} alt="" class="syllabus-module__image" />}
              </div>
              <span class="syllabus-module__chevron" aria-hidden="true"></span>
            </summary>
            <div class="syllabus-module__body">
              <ul class="syllabus-lessons" role="list">
                {modLessons.map((lesson) => (
                  <li class="syllabus-lessons__item">
                    <a href={"/lessons/module-" + lesson.data.module + "/" + lesson.data.lesson} class="syllabus-lesson">
                      <span class="syllabus-lesson__num">{lesson.data.lesson}</span>
                      <div class="syllabus-lesson__body">
                        <span class="syllabus-lesson__title">{lesson.data.title}</span>
                        {lesson.data.summary && <span class="syllabus-lesson__summary">{lesson.data.summary}</span>}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
              {modAssessment && (
                <a href={"/assessments/" + (mod.data.id === "07" ? "capstone" : "module-" + mod.data.id + "-quiz")} class="syllabus-checkin">
                  <span class="type-label syllabus-checkin__label">Module Check-in</span>
                  <span class="syllabus-checkin__title">{modAssessment.data.title}</span>
                </a>
              )}
            </div>
          </details>
        );
      })}
    </section>
  </div>
</Base>
