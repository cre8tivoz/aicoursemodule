---
import Base from "@/layouts/Base.astro";
import { marked } from "marked";

export async function getStaticPaths() {
  const modules = import.meta.glob("/src/content/curriculum/**/*.md", { query: "raw" });
  return Object.entries(modules).map(([path, loader]) => {
    const slug = path.split("/").pop()?.replace(".md", "") ?? "";
    return {
      params: { slug },
      props: { loader },
    };
  });
}

const { loader } = Astro.props;
const rawModule = await loader();
const rawContent = typeof rawModule === "string" ? rawModule : (rawModule as any).default ?? String(rawModule);
const stripped = rawContent
  .replace(/^---\n[\s\S]*?\n---\n?/, "")
  .replace(/^\s*#\s+.+\n/, "");
const contentHtml = marked.parse(stripped) as string;

// Extract title from frontmatter
const titleMatch = rawContent.match(/^title:\s*["']?(.+?)["']?\s*$/m);
const pageTitle = titleMatch ? titleMatch[1] : "Curriculum";
---

<Base title={pageTitle}>
  <article class="lesson-sheet">
    <div set:html={contentHtml} />
  </article>
</Base>
