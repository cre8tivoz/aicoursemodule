---
import "../styles/main.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "AI Essentials for Qualifiers",
  description = "A hands-on course in static-site deployment for AI-fluent graduates.",
  ogImage = "/images/og-image.png",
} = Astro.props;

const site = {
  favicon: "/favicon.svg",
};
const settings = {
  default_theme: "light",
};
const params = {
  course_title: "AI Essentials",
  course_subtitle: "Static HTML Deployment for AI-Flu Graduates",
  course_level: "AQF 5 — Diploma",
};
---

<!doctype html>
<html lang="en" data-theme={settings.default_theme ?? "light"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href={site.favicon} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-frame">
      <!-- Skip links -->
      <a class="skip-link" href="#main">Skip to main content</a>
      <a class="skip-link skip-link--syllabus" href="#course-map">Skip to course map</a>

      <!-- Header -->
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-logo" aria-label={params.course_title + " home"}>
            <span class="site-logo__mark" aria-hidden="true"></span>
            <span>{params.course_title}</span>
          </a>
          <nav aria-label="Primary" class="site-nav">
            <ul class="site-nav__list">
              <li><a href="/" class="site-nav__pill" aria-current={Astro.url.pathname === "/" ? "page" : undefined}>Home</a></li>
              <li><a href="/curriculum/course-outline" class="site-nav__pill" aria-current={Astro.url.pathname.startsWith("/curriculum") ? "page" : undefined}>Curriculum</a></li>
              <li><a href="/lessons/module-01/01" class="site-nav__pill" aria-current={Astro.url.pathname.startsWith("/lessons") ? "page" : undefined}>Lessons</a></li>
              <li><a href="/assessments/module-01-quiz" class="site-nav__pill" aria-current={Astro.url.pathname.startsWith("/assessments") ? "page" : undefined}>Assessments</a></li>
            </ul>
          </nav>

          <!-- Theme Switcher -->
          <fieldset class="theme-switcher">
            <legend class="theme-switcher__legend visually-hidden">Theme</legend>
            <button type="button" class="theme-btn" data-theme-value="light" aria-pressed="false">Light</button>
            <button type="button" class="theme-btn" data-theme-value="mono" aria-pressed="false">Mono</button>
          </fieldset>
        </div>
      </header>

      <!-- Main -->
      <main id="main" class="site-main">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="site-footer">
        <div class="site-footer__inner">
          <p class="site-footer__tagline">{params.course_title}</p>
          <p class="site-footer__note">
            {params.course_subtitle} &middot; {params.course_level}
          </p>
          <nav aria-label="Footer">
            <ul class="site-footer__nav">
              <li><a href="/curriculum/course-outline">Course Outline</a></li>
              <li><a href="/reference/aqf-level-5-descriptor">AQF Descriptor</a></li>
              <li><a href="/assessments/capstone">Capstone</a></li>
              <li><a href="/downloads/capstone-evidence-pack">Evidence pack</a></li>
              <li><a href="/reference/capstone-assessor-rubric">Assessor rubric</a></li>
            </ul>
          </nav>
        </div>
      </footer>
    </div>

    <!-- Keyboard help dialog (hidden by default) -->
    <div id="keyboard-help" class="keyboard-help" hidden aria-modal="true" role="dialog" aria-labelledby="keyboard-help-title">
      <div class="keyboard-help__panel">
        <button class="keyboard-help__close" aria-label="Close" data-action="close-keyboard-help">&times;</button>
        <h2 class="keyboard-help__title" id="keyboard-help-title">Keyboard shortcuts</h2>
        <p class="keyboard-help__intro">Navigate the course without a mouse.</p>
        <dl class="keyboard-help__list">
          <div class="keyboard-help__row"><dt>N</dt><dd>Next page</dd></div>
          <div class="keyboard-help__row"><dt>P</dt><dd>Previous page</dd></div>
          <div class="keyboard-help__row"><dt>T</dt><dd>Theme switcher</dd></div>
          <div class="keyboard-help__row"><dt>?</dt><dd>Show this help</dd></div>
          <div class="keyboard-help__row"><dt>Esc</dt><dd>Close dialogs</dd></div>
        </dl>
      </div>
    </div>

    <script src="/js/app.js" is:inline></script>
  </body>
</html>
